# "production" olarak set edilirse bazı güvenlik kontrolleri daha katı davranır
# (örn. WHATSAPP_APP_SECRET boşken webhook imza doğrulaması atlanmaz, reddedilir).
# Railway'de canlı deploy'da mutlaka ENVIRONMENT=production set edilmeli.
ENVIRONMENT=development

# PostgreSQL
# DATABASE_URL: uygulamanın bağlandığı, kısıtlı (non-superuser) rol — RLS'in
#   gerçekten uygulanması için ZORUNLU. Bkz. backend/alembic/versions/0002_*.
# MIGRATIONS_DATABASE_URL: sadece `alembic upgrade head` için, tablo/rol
#   oluşturma yetkisi olan superuser/owner bağlantısı.
DATABASE_URL=postgresql+psycopg2://portfoyai_app:portfoyai_app@localhost:5432/portfoyai
MIGRATIONS_DATABASE_URL=postgresql+psycopg2://portfoyai:portfoyai@localhost:5432/portfoyai
# AUTH_DATABASE_URL: sadece /auth/register ve /auth/login — e-posta ile ofis
#   bilinmeden kullanıcı arama gerektiği için dar yetkili, BYPASSRLS'li bir rol.
#   Bkz. backend/alembic/versions/0003_auth_bootstrap_role.py.
AUTH_DATABASE_URL=postgresql+psycopg2://portfoyai_auth:portfoyai_auth@localhost:5432/portfoyai

# Auth
JWT_SECRET=change-me-in-production

# Next.js ofis paneli farklı origin'den istek atar; virgülle ayrılmış liste.
CORS_ORIGINS=http://localhost:3000

# LLM
GEMINI_API_KEY=

# Pricing Agent: bölgesel emsal ilan embedding'leri (Sprint 2)
# Boş bırakılırsa ChromaDB'nin yerel varsayılan embedding modeli kullanılır
# (API anahtarı gerektirmez, MVP/test için yeterli).
CHROMA_PERSIST_DIR=./chroma_data

# Voice-to-Listing (Sprint 3)
OPENAI_API_KEY=

# Ulaşım/Konum Raporu (Sprint 3)
GOOGLE_MAPS_API_KEY=

# iyzico Abonelik Yönetimi (Sprint 2)
# Key'ler boşsa /billing/checkout 503 döner, geri kalan her şey normal çalışır.
# Sandbox key'leri iyzico sandbox aktivasyonu sonrası merchant panelinden alınır;
# canlıya geçişte sadece key'ler + IYZICO_BASE_URL=https://api.iyzipay.com değişir.
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# iyzico callback'inin döneceği backend adresi (canlıda Railway URL'i)
PUBLIC_BASE_URL=http://localhost:8010
# Ödeme sonrası kullanıcının döndürüleceği panel adresi (canlıda Vercel URL'i)
FRONTEND_BASE_URL=http://localhost:3000

# WhatsApp Business Cloud API (Sprint 2)
# WHATSAPP_TOKEN: mesaj göndermek için (henüz kullanılmıyor, gelen mesajlar yeterli).
# WHATSAPP_VERIFY_TOKEN: Meta'nın webhook kurulum handshake'i (GET) için, kendi seçtiğin bir değer.
# WHATSAPP_APP_SECRET: gelen webhook isteklerini imzalamak için Meta'nın verdiği app secret;
#   boş bırakılırsa (henüz Meta onayı yoksa) imza doğrulaması atlanır.
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Otomatik WhatsApp takip zinciri: POST /internal/run-follow-ups'ı tetikleyen
# cron'un X-Cron-Secret header'ında göndereceği paylaşılan sır (kendi seçtiğin
# rastgele bir değer). Boş bırakılırsa endpoint 503 döner, zincir hiç çalışmaz.
# Cron önerisi: saatte bir — örn. Railway'de ayrı bir cron servisi ya da
# GitHub Actions schedule ile `curl -X POST -H "X-Cron-Secret: $CRON_SECRET" .../internal/run-follow-ups`
CRON_SECRET=

# Hata izleme
SENTRY_DSN=

# İlan fotoğrafları: herhangi bir S3-uyumlu servis (Railway'in kendi Bucket
# servisi önerilir — ayrı hesap gerekmez). Boş bırakılırsa fotoğraf yükleme
# endpoint'i 503 döner, geri kalan her şey normal çalışır.
# NOT: Railway Buckets (Tigris altyapılı) public bucket erişimini desteklemiyor —
# fotoğraflar her zaman backend proxy'sinden (GET /listings/photos/{key},
# PUBLIC_BASE_URL kullanılarak) servis edilir, ayrı bir public URL değişkeni gerekmez.
S3_ENDPOINT_URL=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
